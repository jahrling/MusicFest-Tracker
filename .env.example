# ── Anthropic ──────────────────────────────────────────────────────────────────
# Required when VISION_BACKEND=claude (default).
# Optional for paddleocr mode — enables a Claude text pass for better accuracy.
ANTHROPIC_API_KEY=sk-ant-...

# ── Spotify ────────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8080/callback as a Redirect URI in the app settings.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# ── Local preferences ──────────────────────────────────────────────────────────
HOME_CITY=Your City, ST
CONCERT_RADIUS_MILES=200
RESEARCH_RANK_THRESHOLD=40

# ── Vision backend ─────────────────────────────────────────────────────────────
#   claude     — Claude vision API (default, no GPU required)
#   paddleocr  — PaddleOCR running locally (GPU recommended; CPU works, just slower)
VISION_BACKEND=claude
# VISION_BACKEND=paddleocr
